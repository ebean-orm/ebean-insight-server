{{<fragments/layout}}
  {{$body}}
    <h1>Label: {{ label }}</h1>
    <p>App: <a href="/app/{{ app.id }}">{{ app.name }}</a></p>
    <p><strong>{{ metrics.size }}</strong> metric variant(s) share this label (each is a distinct SQL hash).</p>

    <table class="table">
      <thead>
      <tr>
        <th>Metric Id</th>
        <th>Hash (key)</th>
        <th>Loc</th>
        <th>SQL</th>
        <th>Plans</th>
      </tr>
      </thead>
      <tbody>
      {{#metrics}}
        <tr>
          <td><a href="/metrics/{{ id }}">{{ id }}</a></td>
          <td><code>{{ key }}</code></td>
          <td>{{ loc }}</td>
          <td><pre style="white-space:pre-wrap; max-width:80ch">{{ sql }}</pre></td>
          <td><a href="/metrics/{{ id }}">view plans</a></td>
        </tr>
      {{/metrics}}
      </tbody>
    </table>
  {{/body}}
{{/fragments/layout}}
